      <schema_name/>
    </partitioning>
    <connection>cleaning_stage</connection>
    <sql>SELECT
  em.EmployeeKey
, job.JobKey
, sat.SatisfactionKey
, per.PerformanceKey
, ﻿Age
, Attrition
, DailyRate
, DistanceFromHome
, HourlyRate
, MonthlyIncome
, MonthlyRate
, NumCompaniesWorked
, PercentSalaryHike
, TotalWorkingYears
, TrainingTimesLastYear
, YearsAtCompany
, YearsInCurrentRole
, YearsSinceLastPromotion
, YearsWithCurrManager
FROM group2_clean.data_clean as dc
JOIN group2_olap.dim_employee as em
	ON dc.EmployeeNumber = em.EmployeeNumber
JOIN group2_olap.dim_job as job
	ON dc.Department = job.Department
	AND dc.JobRole = job.JobRole
	AND dc.JobLevel = job.JobLevel
JOIN group2_olap.dim_satisfaction as sat
	ON dc.EnvironmentSatisfaction = sat.EnvironmentSatisfaction
	AND dc.JobSatisfaction = sat.JobSatisfaction
	AND dc.RelationshipSatisfaction = sat.RelationshipSatisfaction
	AND dc.WorkLifeBalance = sat.WorkLifeBalance
	AND dc.JobInvolvement = sat.JobInvolvement
JOIN group2_olap.dim_performance as per
	ON dc.PerformanceRating = per.PerformanceRating
	AND dc.StockOptionLevel = per.StockOptionLevel
</sql>
    <limit>0</limit>
